NODE_ENV=development
PORT=4100
WEB_ORIGIN=http://localhost:5173
DATABASE_URL=file:./dev.db
SESSION_SECRET=replace-with-a-long-random-secret
UPLOAD_DIR=./uploads
COOKIE_SECURE=false
HTTPS_CERT_FILE=
HTTPS_KEY_FILE=

# ASR provider: disabled | mock | volcengine
# Use mock for local UI/WebSocket testing when Volcengine credentials are not ready.
ASR_PROVIDER=volcengine
ASR_MOCK_TEXT=张三
ASR_MAX_CONCURRENCY=1
VOLCENGINE_ASR_APP_ID=
VOLCENGINE_ASR_ACCESS_TOKEN=
VOLCENGINE_ASR_SECRET_KEY=
VOLCENGINE_ASR_CLUSTER=
VOLCENGINE_ASR_ENDPOINT=wss://openspeech.bytedance.com/api/v2/asr
VOLCENGINE_ASR_FORMAT=pcm
VOLCENGINE_ASR_SAMPLE_RATE=16000
VOLCENGINE_ASR_LANGUAGE=zh-CN
