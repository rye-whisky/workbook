NODE_ENV=development
PORT=4100
WEB_ORIGIN=http://localhost:5173
DATABASE_URL=file:./dev.db
SESSION_SECRET=replace-with-a-long-random-secret
UPLOAD_DIR=./uploads
COOKIE_SECURE=false

# ASR provider: disabled | mock | volcengine
# Use mock for local UI/WebSocket testing when Volcengine credentials are not ready.
ASR_PROVIDER=volcengine
ASR_MOCK_TEXT=张三
VOLCENGINE_ASR_APP_ID=
VOLCENGINE_ASR_ACCESS_TOKEN=
VOLCENGINE_ASR_CLUSTER=
VOLCENGINE_ASR_ENDPOINT=
VOLCENGINE_ASR_FORMAT=pcm
VOLCENGINE_ASR_SAMPLE_RATE=16000
VOLCENGINE_ASR_LANGUAGE=zh-CN
