{
  "name": "@workbook/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup && node scripts/fix-node-sqlite.mjs",
    "start": "node dist/server.js",
    "test": "vitest run --passWithNoTests",
    "db:generate": "tsx src/migrate.ts",
    "db:migrate": "tsx src/migrate.ts"
  },
  "dependencies": {
    "@workbook/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "tesseract.js": "^6.0.1",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/ws": "^8.18.1",
    "supertest": "^7.1.4",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "vitest": "^4.0.15"
  }
}
